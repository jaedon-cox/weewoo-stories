ANTHROPIC_API_KEY=your_anthropic_key_here
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# Supabase PostgreSQL (Settings > Database > Connection string > URI)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Cloudflare R2 (Workers & Pages > R2 > Manage R2 API Tokens)
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_PARTS_BUCKET=autostory-parts
R2_BACKGROUNDS_BUCKET=autostory-backgrounds

# Google Cloud TTS fallback (service account JSON as a single-line string)
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# TikTok OAuth2
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
TIKTOK_REFRESH_TOKEN=your_refresh_token_here

# YouTube OAuth2
YOUTUBE_CLIENT_ID=your_youtube_client_id
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret
YOUTUBE_REFRESH_TOKEN=your_refresh_token_here

# Alert email (optional — for crash notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your_app_password
